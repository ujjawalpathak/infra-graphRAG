Step 4 — Update retrieve() to use HYBRID score

Replace your current retrieve() with this hybrid version:

def retrieve(query: str, k: int = 5) -> List[Dict[str, Any]]:
    if embs is None:
        raise RuntimeError("Embeddings not loaded (embs is None).")

    # Vector similarity
    qv = np.asarray(model.encode(query), dtype="float32")
    vec = cosine_similarities(embs, qv)          # can be negative..positive
    vec_n = normalize_minmax(vec)

    # BM25 keyword relevance
    bm = bm25_scores(query)
    bm_n = normalize_minmax(bm)

    # Weighted hybrid score (tune alpha later)
    alpha = 0.65  # 65% vector, 35% keyword
    hybrid = alpha * vec_n + (1 - alpha) * bm_n

    # Get top candidates by hybrid score
    candidate_pool = 50
    top_idx = np.argsort(-hybrid)[:candidate_pool]

    # For now: take top-k directly (next step can add MMR diversity on top_idx)
    chosen = top_idx[:k]

    out: List[Dict[str, Any]] = []
    for i in chosen:
        rec = chunks[int(i)]
        out.append({
            "score": float(vec[int(i)]),                 # keep cosine for confidence gating
            "hybrid_score": float(hybrid[int(i)]),       # ranking score
            "bm25": float(bm[int(i)]),                   # debug
            "source_file": rec.get("source_file"),
            "chunk_index": rec.get("chunk_index"),
            "chunk_id": rec.get("chunk_id"),
            "text": rec.get("text", ""),
        })

    out.sort(key=lambda x: x["hybrid_score"], reverse=True)
    return out

Important:

Keep score = cosine similarity for your “refuse if weak evidence” gate.

Use hybrid_score for ranking.

